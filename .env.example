# Mini SOC Lab — Environment Configuration
# Copy to .env and update values for your deployment

# Wazuh API connection
VITE_WAZUH_API_URL=https://192.168.56.100:55000
VITE_WAZUH_API_USER=wazuh-wui
VITE_WAZUH_DASHBOARD_URL=https://192.168.56.100:443

# Infrastructure IPs
VITE_SIEM_IP=192.168.56.100
VITE_WIN_EP_IP=192.168.56.10
VITE_LINUX_EP_IP=192.168.56.11
VITE_HOST_IP=192.168.56.1
VITE_NETWORK_SUBNET=192.168.56.0/24

# Feature flags
# Set to "true" to fetch live data from Wazuh API instead of fallback data
VITE_USE_LIVE_DATA=false
# Set to "true" to allow pushing config changes to agents
VITE_ENABLE_AGENT_PUSH=false

# Polling intervals (milliseconds)
VITE_DASHBOARD_REFRESH=60000
VITE_DASHBOARD_REFRESH_REALTIME=10000
VITE_AGENT_HEALTH_REFRESH=300000
VITE_AUTH_MONITOR_REFRESH=30000

# Wazuh API request timeout (milliseconds)
VITE_WAZUH_REQUEST_TIMEOUT=10000
